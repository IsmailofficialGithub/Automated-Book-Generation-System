# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini

# LLM Provider: anthropic | openai
LLM_PROVIDER=anthropic

# Redis — local Docker default; Redis Cloud needs host/port + REDIS_PASSWORD
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEET_TAB=Sheet1
GOOGLE_SHEET_RANGE=A1:G200

# Notifications — Email (Gmail: 2FA on, then App password — 16 chars; spaces in the UI are optional in .env)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=editor@yourcompany.com

# Notifications — MS Teams
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# App
NODE_ENV=development
PORT=3000
# Browser origins for the Vite dev server (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
POLL_INTERVAL_MS=15000
# false = no Redis required: health, /sync-sheet, /books, approvals, final-review. true = start Redis + workers (Docker compose).
ENABLE_BACKGROUND_JOBS=false
# true = generate chapters once outline exists even if status_outline_notes is still "no". false = require no_notes_needed first.
ALLOW_CHAPTERS_WITHOUT_OUTLINE_APPROVAL=true
